GROQ_API_KEY=your_groq_api_key_here

# --- Quick setup ---
# 1. Copy this file to .env and set GROQ_API_KEY
# 2. Run: .\scripts\setup-env.ps1
# 3. Merge optional defaults from docs\recommended.env
# 4. Verify: python -m mango --doctor
#
# Suggested Groq model (change if doctor warns it is unavailable on your key):
GROQ_MODEL=llama-3.3-70b-versatile
# Push-to-talk (hold while speaking). Run terminal as Admin if the key does nothing globally.
HOTKEY=alt+w

# LLM backend: groq (cloud, default) | ollama (local via OpenAI-compatible API).
# MANGO_LLM_PROVIDER=groq
# When using Ollama (https://ollama.com): pull a tool-capable model first, e.g. ``ollama pull llama3.2``
# MANGO_LLM_PROVIDER=ollama
# Base URL (scheme optional if you use OLLAMA_HOST=127.0.0.1:11434)
# MANGO_OLLAMA_BASE_URL=http://127.0.0.1:11434
# Or set OLLAMA_HOST=127.0.0.1:11434
# MANGO_OLLAMA_MODEL=llama3.2

# Discord voice bridge (optional): run as a separate selfbot process — ``python -m mango --discord-voice``
# Uses discord.py-self (https://discordpy-self.readthedocs.io/) + FFmpeg on PATH. The bridge logs in
# with a **user account token**, NOT an application bot token — this is required so it can join 1:1 DM
# and group-DM calls. WARNING: automating user accounts violates the Discord ToS and can lead to
# account termination; use a throwaway account you do not mind losing.
# MANGO_DISCORD_BOT_TOKEN=
# (Alias: DISCORD_BOT_TOKEN)
# Localhost control for the desktop ``discord_voice`` tool (127.0.0.1 only). Secret is optional:
# if unset, no auth header; if set, bridge + desktop must use the same value in header X-Mango-Discord-Control.
# MANGO_DISCORD_CONTROL_SECRET=
# MANGO_DISCORD_VOICE_CONTROL_PORT=37564
# Optional: numeric Discord user id whose current channel should be preferred by ``sync``
# (defaults to the selfbot account itself, which is usually what you want).
# MANGO_DISCORD_OWNER_USER_ID=
# Optional: only consider server voice channels in this guild (snowflake id). When set, DM and
# group calls are excluded from status/sync.
# MANGO_DISCORD_PREFERRED_GUILD_ID=
# Optional: text channel id where ``sync`` can @mention friends when no qualifying VC exists.
# MANGO_DISCORD_NOTIFY_CHANNEL_ID=
# After login, auto-run the same join logic as ``discord_voice`` ``sync`` (~4s delay). Uses small-call defaults.
# MANGO_DISCORD_AUTO_SYNC_ON_READY=1
# With auto-sync: set to 0 to allow joining larger calls (default 1 = only_small_group_calls on).
# MANGO_DISCORD_AUTO_SYNC_ONLY_SMALL=1

# Trim rolling chat history (non-system messages). Default 36, clamped 8–128 (or up to 512 when MANGO_PERSISTENT_MEMORY=1).
# MANGO_MAX_CONVERSATION_MESSAGES=36

# Persistent conversation memory (JSON on disk — opt-in; plaintext including tool payloads).
# Survives restarts; oldest turns drop when over the cap. Daily UTC snapshots in memory/days/ unless disabled.
# Memory tier (recommended: session until you want cross-restart memory). See docs/memory-tiers.md
# - session: nothing on disk after quit (default, most private)
# - day: same-day continuity on disk (plaintext)
# - profile: long-lived memory on disk (plaintext)
MANGO_MEMORY_TIER=session
# MANGO_PERSISTENT_MEMORY=1
# MANGO_MEMORY_DIR=
# MANGO_MEMORY_MAX_MESSAGES=120
# MANGO_MEMORY_MERGE_DAYS=14
# MANGO_MEMORY_DAILY_SNAPSHOTS=1

# Spotify: resolve song names to playable tracks (spotify_play). Optional but best accuracy:
# Create a free app at https://developer.spotify.com/dashboard → Client ID + Client Secret (Client Credentials).
# MANGO_SPOTIFY_CLIENT_ID=
# MANGO_SPOTIFY_CLIENT_SECRET=
# (Aliases: SPOTIFY_CLIENT_ID / SPOTIFY_CLIENT_SECRET)
# Default: Mango opens the Spotify app with spotify:track:…:play so the desktop queue switches to the new song.
# Set MANGO_SPOTIFY_INLINE_PREVIEW=1 to play Spotify’s ~30s preview inside Mango instead (no app handoff; won’t switch Spotify).
# MANGO_SPOTIFY_INLINE_PREVIEW=0
# Always open the Spotify app and never use inline preview (same as default unless INLINE_PREVIEW is on).
# MANGO_SPOTIFY_FORCE_APP=1
# How Spotify opens from Mango: 1 = minimized / try not to steal focus (default), 0 = normal foreground.
# MANGO_SPOTIFY_MINIMIZED=1
# When 1 on Windows: after Connect plays, URI opens, or media-key skip — briefly foreground Spotify, then minimize again.
# MANGO_SPOTIFY_TRACK_CHANGE_UI_MS=400
# Duck Spotify *session* volume during wake turns: after "hey mango" ack through LLM/tools/reply TTS (Windows; pycaw/comtypes).
# MANGO_SPOTIFY_DUCK=1
# MANGO_SPOTIFY_DUCK_VOLUME=0.12
# MANGO_SPOTIFY_DUCK_FLOOR=0.02
# If MANGO_SPOTIFY_MINIMIZED=0: URI opens try Spotify.exe then ShellExecuteW / start / os.startfile without the foreground-then-minimize track-change cycle.
# Optional full path to Spotify.exe if not under %%LOCALAPPDATA%%\Spotify (Windows track-switch handoff).
# MANGO_SPOTIFY_EXE=
# 1 = when searching by title, skip obvious instrumental/karaoke hits and prefer higher Spotify popularity (default).
# MANGO_SPOTIFY_PREFER_VOCALS=1
# Desktop-first (typical): leave MANGO_SPOTIFY_WEB_PLAYBACK unset or 0 — Mango opens Spotify minimized (MANGO_SPOTIFY_MINIMIZED)
# and spotify_transport uses Windows media keys for skip/pause. Set WEB_PLAYBACK=1 for in-browser Web Playback (Premium) instead.
# 1 (default): with spotify_session login, try Spotify Web API (Connect) on the desktop app before URI handoff — less window focus-steal.
# MANGO_SPOTIFY_DESKTOP_API=1
# Optional substring to pick a Connect device by name when you have several (else prefers type Computer).
# MANGO_SPOTIFY_DEVICE_NAME=
# Set redirect URI on your Spotify app to http://127.0.0.1:8765/callback (or override with MANGO_SPOTIFY_REDIRECT_URI).
# MANGO_SPOTIFY_WEB_PLAYBACK=1
# MANGO_SPOTIFY_REDIRECT_URI=http://127.0.0.1:8765/callback
# Local page for the Web Playback SDK (default 9876). HTML is served by Mango; open once after login.
# MANGO_SPOTIFY_PLAYER_PORT=9876
# 1 = Mango may open your default browser to the player URL on first web play; 0 (default) = only log the URL — open it yourself once and pin the tab.
# MANGO_SPOTIFY_AUTO_OPEN_PLAYER=0
# Optional override for saved refresh token JSON path (default ~/.mango/spotify_user_token.json).
# MANGO_SPOTIFY_USER_TOKEN_PATH=
# After enabling: use tool ``spotify_session`` action login once; keep the player tab open while listening.
# ``spotify_transport`` uses Web API when web playback is on; otherwise Windows media keys. ``spotify_play`` starts tracks.

# Push-to-talk combo (keyboard library names). Default: Alt+W
# HOTKEY=alt+w
# Continuous listen (energy VAD): 1 / true / yes / on. For one run of Alt+W-only: ``python -m mango.main --ptt-only``
# MANGO_ALWAYS_LISTEN=1
# With always-listen: only answer VAD turns whose transcript *starts* with the phrase (no LLM/TTS otherwise).
# MANGO_ALWAYS_LISTEN_REQUIRE_PREFIX=1
# Phrase(s) for that gate: comma-separated (e.g. hey mango,hey mingo,mango). With MANGO_ALWAYS_LISTEN_PREFIX_ONLY=1,
# your list is merged with built-in mishears (hey/hay/hi/yo + mango variants; non-hey: main go, mingo, margo, …).
# MANGO_ALWAYS_LISTEN_PREFIX=hey mango
# One switch: always-listen + require-prefix on, wake/OWW off (prefix-only mode).
# MANGO_ALWAYS_LISTEN_PREFIX_ONLY=1
# After a skipped turn (no TTS: rejected prefix, empty STT, short clip): unsuppress delay (default 0.08s; was effectively wake_post_tts before).
# MANGO_SUPPRESS_AFTER_SKIPPED_TURN_SECONDS=0.08
# VAD: max seconds waiting for speech before yielding mic (default 3.5; lower = re-arm sooner).
# MANGO_VAD_MAX_WAIT_SECONDS=2.5
# VAD thread sleep when idle (default 0.022; lower = listen again sooner; 0 = tight loop — not recommended).
# MANGO_VAD_THREAD_IDLE_SLEEP_SECONDS=0.022
# Test openWakeWord wake (no always-listen): ``python -m mango.main --wake-oww-only`` → hybrid (OWW + Whisper phrase check). ``--wake-oww-score-only`` → OWW score only. Needs MANGO_OWW_MODELS or ``scripts\run_mango_oww_test.ps1`` with a path.
# Wake word: OFF by default. Set MANGO_WAKEWORD=1 for hands-free phrase then one listen.
# MANGO_WAKEWORD=1
# MANGO_WAKE_PHRASE=mango
# (Optional alternatives for hybrid / Whisper wake: comma-separated, e.g. hey mango,hey mingo)
# Wake backend: auto (use openWakeWord when models resolve) | whisper | openwakeword | hybrid
# MANGO_WAKE_ENGINE=auto
# Comma-separated openWakeWord built-in names (hey_jarvis, alexa, …) or paths to .onnx/.tflite models.
# MANGO_OWW_MODELS=hey_jarvis
# MANGO_OWW_THRESHOLD=0.5
# Silero VAD gate inside openWakeWord (0 = off). Values > 0 require voiced frames before scores count;
# many users find ~0.5 helps with TV/background speech false positives (tune per room).
# MANGO_OWW_VAD_THRESHOLD=0
# Example for noisy rooms (uncomment to try):
# MANGO_OWW_VAD_THRESHOLD=0.5
# onnx (default on Windows) | tflite
# MANGO_OWW_INFERENCE=onnx
# Colab / training gotchas (onnx_tf, AudioSet URLs, Speex, pip churn): mango/WAKE_OWW.md
# When wake is on, default is streaming+VAD (speech starts capture). Set 0 for old fixed-interval blind clips.
# MANGO_WAKE_STREAMING=1
# Streaming wake runs Whisper often; faster_whisper logs "Processing audio…" at INFO each time — suppressed by default in mango/logging_setup.py.
# MANGO_VERBOSE_FASTER_WHISPER=1
# Optional smaller/faster Whisper only for wake (e.g. tiny.en). Empty = same as MANGO_WHISPER_MODEL.
# MANGO_WAKE_WHISPER_MODEL=tiny.en
# Streaming wake tuning (only when MANGO_WAKE_STREAMING is on or default-on with wake).
# MANGO_WAKE_STREAM_SILENCE_MS=720
# MANGO_WAKE_STREAM_MAX_SECONDS=2.5
# MANGO_WAKE_STREAM_MIN_SPEECH_MS=150
# Polled wake only: how often to grab a blind clip (seconds; min 1). Ignored when streaming wake is on.
# MANGO_WAKE_INTERVAL_SECONDS=4
# MANGO_WAKE_CLIP_SECONDS=1.8
# RMS pre-gate before Whisper (0 = disabled). Example: 0.008
# MANGO_WAKE_RMS_THRESHOLD=0
# Skip Whisper on near-silent wake clips (stops "Thank you" hallucinations). float32 peak abs, default 0.004
# MANGO_WAKE_WHISPER_MIN_PEAK=0.004
# Skip flat / low-variance wake clips (sample std dev of float32 waveform, default 0.012)
# MANGO_WAKE_WHISPER_MIN_STD=0.012
# Streaming-wake energy VAD: RMS vs noise floor to start/sustain capture (defaults match old hard-coded gates).
# Distant mic: try lower HI_FLOOR (e.g. 0.0055) and slightly lower HI_MULT (e.g. 2.2); watch for false wakes.
# MANGO_WAKE_STREAM_SPEECH_HI_FLOOR=0.009
# MANGO_WAKE_STREAM_SPEECH_HI_MULT=2.75
# MANGO_WAKE_STREAM_SPEECH_LO_FLOOR=0.006
# MANGO_WAKE_STREAM_SPEECH_LO_MULT=1.65
# MANGO_HANDS_FREE_SECONDS=10
# Listen cue (two-tone earcon before mic open).
# MANGO_LISTEN_CHIME_WAKE=1
# MANGO_LISTEN_CHIME_PTT=0
# Quiet hours: skip startup intro + shorter-reply system hint. e.g. 22–07 night window.
# MANGO_QUIET_HOURS=22-7
# MANGO_QUIET_TIMEZONE=America/Chicago
# Truncate tool results before sending to the LLM (2000–100000, default 10000)
# MANGO_MAX_TOOL_OUTPUT_CHARS=10000
# Cap spoken reply length before TTS (80–1200, default 1200)
# MANGO_MAX_SPOKEN_REPLY_CHARS=1200
# Stream TTS in sentence chunks (set 0 to send whole reply at once)
# MANGO_STREAMING_TTS=1
# Short spoken line on unexpected loop errors
# MANGO_SPEAK_ON_ERROR=1
# Require explicit "phone/contact/number" wording before revealing saved contact numbers (default on)
# MANGO_CONTACT_INFO_REQUIRE_INTENT=1
# Session transcript on exit: %USERPROFILE%\.mango\logs (plaintext — off by default).
# MANGO_SESSION_LOG_DIR=
# Enable session markdown on exit: MANGO_SESSION_LOG=1

# Optional: sounddevice input device index if the wrong mic is used (see python -m sounddevice).
# MANGO_SD_INPUT_DEVICE=12
# MANGO_MIN_RECORD_SECONDS=0.25
# MANGO_EDGE_VOICE=en-US-GuyNeural
# MANGO_SEARCH_MAX_RESULTS=25

# Cap LLM↔tool turns per utterance (default 6, clamped 2–24). Use 10 if multi-step Discord+Spotify
# turns sometimes hit the limit before the host early-exit kicks in.
# MANGO_MAX_LLM_TOOL_ROUNDS=10

# Human-facing name in system prompt + phone/Discord copy (default: Windows username, title-cased).
# MANGO_OWNER_NAME=Dylan
# Comma-separated phone_call contact slugs (letters, digits, underscore; default ariana,brooke,dylan).
# MANGO_PHONE_CONTACTS=ariana,brooke,dylan
# Optional display override per slug: MANGO_CONTACT_ARIANA_DISPLAY=Ariana
# saved_contact_phone tool reads these for "what's X's number?" (no call). phone_call dials out.

# Discord voice bridge: optional JSON map of Discord usernames → roster display names (overrides built-in defaults).
# MANGO_DISCORD_KNOWN_PEOPLE_JSON={"lovee_ariana":"Ariana",".brook.e":"Brooke","onlydecisions":"Dylan"}
# Selfbot login username when it differs from the default key used in the built-in map:
# MANGO_DISCORD_SELFBOT_USERNAME=onlydecisions
# Comma-separated Discord usernames to exclude from greet_everyone (owner alt accounts):
# MANGO_DISCORD_GREET_EXCLUDE_USERNAMES=onlydecisions

# Wake hands-free: stop recording after sustained silence (ms / RMS block gate)
# MANGO_HANDS_FREE_SILENCE_MS=1000
# MANGO_HANDS_FREE_SILENCE_RMS=0.018
# Stricter tool-args discipline in system prompt
# MANGO_STRICT_TOOLS=0

# Spoken confirmations (per-tool). Defaults: PowerShell on, phone off, Xbox turn_off off.
MANGO_REQUIRE_POWERSHELL_CONFIRMATION=1
MANGO_REQUIRE_PHONE_CONFIRMATION=0
MANGO_REQUIRE_XBOX_TURNOFF_CONFIRMATION=0
# Legacy aggregate switch (applies to all three when per-tool vars are unset):
# MANGO_REQUIRE_TOOL_CONFIRMATION=0

# Hide tools you never use (comma-separated names). Example disables Discord/Xbox/phone/extras:
# MANGO_DISABLED_TOOLS=discord_voice,xbox_console,phone_call,therapy_support,product_research,globe_state,globe_view

# read_clipboard: when 1, only run if the user’s utterance clearly mentions clipboard/paste (default off).
# MANGO_CLIPBOARD_REQUIRE_INTENT=0

# Discord voice: when 1, enforce music / @ping / “join other” phrasing in the user text (default off = relaxed).
# MANGO_DISCORD_STRICT_INTENTS=0

# Sanity check without loading pygame/mic: ``python -m mango --doctor``

# Short behavior preset appended to the system prompt.
# default | research | coding | home | mango_mlx  (jarvis_mlx is an alias for mango_mlx)
# MANGO_PRESET=default
# Honorific: sir | maam | none | unset (unset = prefer sir, never ma'am unless user explicitly asks for ma'am).
# MANGO_HONORIFIC=sir
# Personal "skills" as Markdown: drop *.md under %USERPROFILE%\.mango\skills (UTF-8).
# Override directory:
# MANGO_SKILLS_DIR=C:\Users\You\Documents\MangoSkills
# Total injected characters (500–12000, default 3500):
# MANGO_SKILLS_MAX_CHARS=3500

# Text-to-speech: edge (default, Microsoft Edge TTS, free) | elevenlabs (paid API)
# Must be exactly ``edge`` or ``elevenlabs`` (typos raise at startup).
# MANGO_TTS_PROVIDER=edge
# Where Mango speaks replies: headset (default, pygame) | discord (POST to voice bridge — no local reply audio).
# MANGO_TTS_PLAYBACK=headset
# MANGO_TTS_PLAYBACK=discord
# For ElevenLabs (https://elevenlabs.io → Profile → API key). Voices → copy Voice ID.
# Example placeholder only — use your real key in .env (not committed).
# ELEVENLABS_API_KEY=sk_d998b501efa96a898a890b1099a14ed27e5e81173295465f
# ELEVENLABS_VOICE_ID=jfIS2w2yJi0grJZPyEsk
# Optional models (defaults shown):
# ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
# ELEVENLABS_STS_MODEL=eleven_multilingual_sts_v2
# Optional: run Speech-to-Speech (voice changer) on top of each TTS clip — slower, uses credits twice.
# MANGO_ELEVENLABS_STS_AFTER_TTS=0
# Optional API host if ElevenLabs routes you to a residency endpoint:
# ELEVENLABS_API_BASE=https://api.elevenlabs.io
# Whisper preload is ON by default so first request does not pause to load model weights.
# Set to 0 to disable startup preload (reduces startup CPU/RAM, slower first request).
# MANGO_PRELOAD_WHISPER=0
# Smaller/faster local STT (slightly less accurate): tiny.en, small.en, base.en (default)
# MANGO_WHISPER_MODEL=tiny.en
# No quotes around the key.
# Mango loads the project's .env (next to the mango package) first; override=True means .env beats stale shell vars.

# Mango orb HUD (separate pygame process so SDL audio stays on the main process).
# Ball size / motion follow TTS loudness while state is speaking; idle when listening/thinking.
# MANGO_HUD=1
# Legacy alias: MANGO_JARVIS_HUD=1
# Window starts square (px); drag edges or maximize — resizable when not fullscreen.
# MANGO_HUD_SIZE=880   MANGO_HUD_FULLSCREEN=1
# Sphere radius as fraction of min window side (default 0.30): MANGO_HUD_BALL_RADIUS=0.28
# Dot count override: MANGO_HUD_BALL_DOTS=900
# Supersample 1–3 (default 2): MANGO_HUD_RENDER_SCALE=2
# Cap redraw rate (default 55): MANGO_HUD_FPS=55

# Spoken greeting at launch (time; optional weather). Disable with MANGO_STARTUP_INTRO=0
# Weather is fetched only when ALL three are set (Open-Meteo; no API key):
# MANGO_INTRO_PLACE_NAME=Your City
# MANGO_INTRO_LAT=41.9295
# MANGO_INTRO_LON=-88.7504
# MANGO_INTRO_TIMEZONE=America/Chicago

# Optional: push-to-talk key name for the keyboard library (default: v)
# HOTKEY=v

# Optional: Hugging Face token — only if Hub rate-limits your Whisper model downloads
# HF_TOKEN=

# Logging: INFO (default), DEBUG, WARNING, ERROR
# MANGO_LOG_LEVEL=INFO
# Optional rotating runtime file log (empty = stdout only):
# MANGO_LOG_FILE=logs/mango-runtime.log
# MANGO_LOG_MAX_BYTES=1048576
# MANGO_LOG_BACKUPS=5
# Optional metrics JSONL output (empty = disabled):
# MANGO_METRICS_JSONL=logs/mango-metrics.jsonl
# Optional shared timeout tuning (seconds):
# MANGO_HTTP_TIMEOUT_SHORT_S=12
# MANGO_HTTP_TIMEOUT_MEDIUM_S=25
# MANGO_HTTP_TIMEOUT_LONG_S=35
# Interruption profile for turn/wake behavior: strict | normal | fast
# strict = harder to interrupt, fast = quickest barge-in.
# MANGO_INTERRUPT_PROFILE=normal

# Whisper Silero VAD (default off). On quiet headsets VAD can delete all audio — only enable in noisy rooms.
# MANGO_WHISPER_VAD_FILTER=1

# Quiet mic tuning (defaults work well with boosted/normalized audio).
# Higher no_speech = harder for Whisper to classify clip as "silent". Typical default in faster-whisper is 0.6; Mango uses 0.82.
# MANGO_WHISPER_NO_SPEECH_THRESHOLD=0.82
# More negative log_prob = accept lower-confidence decoding.
# MANGO_WHISPER_LOG_PROB_THRESHOLD=-1.5

# Software gain before Whisper (peak scaled toward this value). Set to 0 to disable.
# MANGO_AUDIO_NORMALIZE_TARGET_PEAK=0.5
# MANGO_AUDIO_NORMALIZE_MAX_GAIN=120

# Set to 1 to log raw HTTP from Groq client libraries (very noisy)
# MANGO_VERBOSE_HTTP=

# Windows TTS playback: pygame/SDL audio backend before Mango loads pygame (see early bootstrap in main).
# Default directsound — best compatibility with screen recorders / desktop-audio capture.
# wasapi can fix silent BT headsets but some recorders (exclusive WASAPI loopback) then won't mix Mango in.
# MANGO_SDL_AUDIODRIVER=directsound
# MANGO_SDL_AUDIODRIVER=wasapi
