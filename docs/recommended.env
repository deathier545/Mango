# Copy lines you want into your repo-root .env (merge with GROQ_API_KEY).
# Run: .\scripts\setup-env.ps1  then edit .env

# --- Stable Groq + push-to-talk ---
GROQ_MODEL=llama-3.3-70b-versatile
# If that model 404s on your account, try: llama-3.1-8b-instant
HOTKEY=alt+w

# --- Memory: session = nothing on disk after quit (recommended start) ---
MANGO_MEMORY_TIER=session

# --- Tool safety (PowerShell stays gated) ---
MANGO_REQUIRE_POWERSHELL_CONFIRMATION=1
MANGO_REQUIRE_PHONE_CONFIRMATION=0
MANGO_REQUIRE_XBOX_TURNOFF_CONFIRMATION=0

# --- Disable integrations you do not use (comma-separated tool names) ---
# Keeps the model focused and avoids accidental Discord/phone/Xbox calls.
MANGO_DISABLED_TOOLS=discord_voice,xbox_console,phone_call,therapy_support,product_research,globe_state,globe_view

# --- TTS (free Edge while ElevenLabs credits are out) ---
MANGO_TTS_PROVIDER=edge
MANGO_EDGE_VOICE=en-US-GuyNeural
# MANGO_ELEVENLABS_QUOTA_EXCEEDED=1
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# --- Tool narration (Jarvis-style; set AFTER=1 for confirm-after each step) ---
MANGO_TOOL_NARRATION=1
MANGO_TOOL_NARRATION_AFTER=0
MANGO_DEFAULT_BROWSER=edge

# --- Desktop orb (optional; Electron UI sets MANGO_HUD=0 on its Python child) ---
# MANGO_HUD=1

# --- Wake word (optional) ---
# MANGO_WAKEWORD=1
# MANGO_WAKE_PHRASE=mango
